          "expr": "sum by (model) (rate(honeybeepf_llm_tokens_total{target_namespace=~\"$team\", target_pod_name=~\"$pod\", model=~\"$model\"}[1m])) * 60",
          "legendFormat": "{{ model }}",
          "refId": "A"
