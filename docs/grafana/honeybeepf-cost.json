          "expr": "topk(10, sum by (target_namespace, target_pod_name) (increase(honeybeepf_llm_tokens_total{target_namespace=~\"$team\", target_pod_name=~\"$pod\", model=~\"$model\"}[5m])))",
          "legendFormat": "{{ target_namespace }} / {{ target_pod_name }}",
          "refId": "A"
        }
      ]
    }
